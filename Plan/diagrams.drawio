                <mxCell id="Qjcx3N9V2EI916u-5tYA-4" value="&lt;font face=&quot;Source Code pro&quot;&gt;&lt;b&gt;Retransmit&lt;/b&gt; last packet&amp;nbsp;&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
                    <mxGeometry x="630" y="220" width="80" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-12" style="edgeStyle=none;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;rounded=1;curved=0;" edge="1" parent="1" source="Qjcx3N9V2EI916u-5tYA-5" target="Qjcx3N9V2EI916u-5tYA-1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="80" y="400"/>
                            <mxPoint x="80" y="260"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-5" value="&lt;font face=&quot;Source Code pro&quot; style=&quot;font-size: 11px;&quot;&gt;Request Retransmit&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
                    <mxGeometry x="280" y="360" width="80" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-24" style="edgeStyle=none;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="Qjcx3N9V2EI916u-5tYA-8" target="Qjcx3N9V2EI916u-5tYA-9">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-8" value="&lt;font face=&quot;Source Code pro&quot; style=&quot;font-size: 11px;&quot;&gt;Transmit acknowledge&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
                    <mxGeometry x="345" y="80" width="80" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-9" value="&lt;font face=&quot;Source Code pro&quot; style=&quot;font-size: 11px;&quot;&gt;Store packet in buffer&lt;/font&gt;" style="whiteSpace=wrap;html=1;aspect=fixed;" vertex="1" parent="1">
                    <mxGeometry x="210" y="80" width="80" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-20" value="&lt;font style=&quot;font-size: 11px;&quot; face=&quot;Source Code pro&quot;&gt;Is ReTx&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="515" y="228" width="70" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-21" value="&lt;font style=&quot;font-size: 11px;&quot; face=&quot;Source Code pro&quot;&gt;Is Ack&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="280" y="10" width="60" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="Qjcx3N9V2EI916u-5tYA-31" style="edgeStyle=none;html=1;entryX=0.345;entryY=0.015;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="Qjcx3N9V2EI916u-5tYA-9" target="Qjcx3N9V2EI916u-5tYA-1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="170" y="120"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sBc_iSO-j17HYmHOk03w-2" value="Packet state machine" style="text;strokeColor=none;fillColor=none;html=1;fontSize=24;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
                    <mxGeometry x="140" y="-180" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sBc_iSO-j17HYmHOk03w-3" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;- 3 states for receiving the bytes: Length, data, and crc fields&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;- When the crc has been received, a crc is computed from the packet contents (length + data)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- If it doesn&#39;t match request a retransmission (ReTx) and start again&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- If the packet is not an *Ack*, send an Ack and pushes the packet into packet buffer&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Start again&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="55" y="-130" width="530" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="sBc_iSO-j17HYmHOk03w-4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="29" y="-180" width="764" height="714" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
